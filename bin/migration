#!/usr/bin/env bash

set -euo pipefail

COMMAND="${1:-help}"

case $COMMAND in
    generate)
        # New migration
        if [ -z "${2-}" ]; then
            echo "Usage: migration generate \"migration name\""
            exit 1
        fi

        exec alembic -c $APPDIR/alembic.ini revision --autogenerate -m "$2"
        ;;
    
    upgrade)
        # Execute migrations (defaults to head)
        REVISION="${2:-head}"
        exec alembic -c $APPDIR/alembic.ini upgrade "$REVISION"
        ;;

    downgrade)
        # Rollback to a specific migration or revision
        if [ -z "${2-}" ]; then
            echo "Usage: migration downgrade <revision>"
            exit 1
        fi

        exec alembic -c $APPDIR/alembic.ini downgrade "$2"
        ;;

    help|*)
        echo "Usage: migration <command>"
        echo "Available commands: generate, upgrade, downgrade"
        exit 1
        ;;
esac